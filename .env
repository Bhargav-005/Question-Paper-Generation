
# Application Configuration
PORT=5000
NODE_ENV=development

# Development Settings (for testing only)
BYPASS_EMAIL_CONFIRMATION=true

# Question Generation — Duplicate Prevention
# Set to 'false' to disable ALL deduplication and revert to original behaviour
ENABLE_DEDUP=true

# Concept-Level Deduplication (v3+)
# Set to 'false' to disable concept-hash checks only (wording dedup still active)
ENABLE_CONCEPT_DEDUP=true

DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/qpaper
JWT_SECRET=supersecretkey